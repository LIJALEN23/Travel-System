<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.swu.tourismmanagesystem.mapper.HotelMapper">

    <!-- 1. 查询所有饭店 -->
    <select id="selectAllHotel" resultType="com.swu.tourismmanagesystem.entity.hotel.HotelBase">
        SELECT * FROM hotel_base
    </select>
    <!-- ==================== 根据景区ID查询关联酒店 ==================== -->
    <!-- 根据景区名称查询关联酒店（核心修改） -->
    <select id="selectHotelByScenicSpotName" resultType="com.swu.tourismmanagesystem.entity.hotel.HotelBase">
        SELECT h.*
        FROM hotel_base h
        -- 关联酒店-景区关联表
        INNER JOIN hotel_scenic_relation r ON h.id = r.hotel_id
        -- 关联景区表（通过scenic_id匹配）
        INNER JOIN scenic_spot s ON r.scenic_id = s.id
        -- 按景区名称
        WHERE s.spot_name = #{spotName}
    </select>

    <!-- 2. 根据ID查询饭店详情 -->
    <select id="selectHotelDetailById" resultType="com.swu.tourismmanagesystem.entity.hotel.HotelBase">
        SELECT * FROM hotel_base WHERE id = #{hotelId}
    </select>

    <!-- 3. 查询饭店管理人员 -->
    <select id="selectManagerByHotelId" resultType="com.swu.tourismmanagesystem.entity.hotel.HotelManager">
        SELECT * FROM hotel_manager WHERE hotel_id = #{hotelId}
    </select>

    <!-- 4. 查询应急救援信息 -->
    <select id="selectEmergencyByHotelId" resultType="com.swu.tourismmanagesystem.entity.hotel.HotelEmergency">
        SELECT * FROM hotel_emergency WHERE hotel_id = #{hotelId}
    </select>
    <!-- ========== 查询酒店最大容纳量 ========== -->
    <select id="selectMaxCapacityByHotelId" resultType="java.lang.Integer">
        SELECT max_capacity FROM hotel_base WHERE id = #{hotelId}
    </select>
    <!-- ==================== 组合条件查询（模糊+星级+开业） ==================== -->
    <select id="selectHotelByCondition" resultType="com.swu.tourismmanagesystem.entity.hotel.HotelBase">
        SELECT * FROM hotel_base
        WHERE status = 1  <!-- 只显示开业酒店 -->

        <if test="hotelName != null and hotelName != ''">
            AND hotel_name LIKE CONCAT('%', #{hotelName}, '%')
        </if>

        <if test="starLevel != null">
            AND star_level = #{starLevel}
        </if>
    </select>
    <!-- ====================== 酒店实时数据 ====================== -->
    <resultMap id="hotelRealTimeMap" type="com.swu.tourismmanagesystem.entity.hotel.HotelRealTimeData">
        <id column="id" property="id"/>
        <result column="hotel_id" property="hotelId"/>
        <result column="current_visitors" property="currentVisitors"/>
        <result column="remaining_parking" property="remainingParking"/>
        <result column="occupancy_rate" property="occupancyRate"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectRealDataByHotelId" resultMap="hotelRealTimeMap">
        select * from hotel_real_time_data where hotel_id = #{hotelId}
    </select>

    <insert id="insertRealTimeData">
        insert into hotel_real_time_data(hotel_id, current_visitors, remaining_parking, occupancy_rate, update_time)
        values(#{hotelId}, #{currentVisitors}, #{remainingParking}, #{occupancyRate}, NOW())
    </insert>

    <update id="updateRealTimeData">
        update hotel_real_time_data
        set current_visitors = #{currentVisitors},
        remaining_parking = #{remainingParking},
        occupancy_rate = #{occupancyRate}
        where hotel_id = #{hotelId}
    </update>
    <!--返回所有带有实时数据的酒店id-->
    <select id="selectHotelIdsWithRealData" resultType="java.lang.Long">
        SELECT DISTINCT hotel_id
        FROM hotel_real_time_data
        WHERE hotel_id IS NOT NULL
    </select>
</mapper>

