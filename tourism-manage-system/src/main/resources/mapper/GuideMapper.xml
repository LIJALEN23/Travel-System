<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.swu.tourismmanagesystem.mapper.GuideMapper">

    <!-- ====================== 1. 导游基础信息 ====================== -->
    <resultMap id="guideMap" type="com.swu.tourismmanagesystem.entity.guide.Guide">
        <id column="id" property="id"/>
        <result column="guide_name" property="guideName"/>
        <result column="phone" property="phone"/>
        <result column="id_card" property="idCard"/>
        <result column="gender" property="gender"/>
        <result column="age" property="age"/>
        <result column="address" property="address"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertGuide">
        insert into guide(guide_name, phone, id_card, gender, age, address, status)
        values(#{guideName}, #{phone}, #{idCard}, #{gender}, #{age}, #{address}, #{status})
    </insert>

    <update id="updateGuide">
        update guide
        <set>
            <if test="guideName != null">guide_name=#{guideName},</if>
            <if test="phone != null">phone=#{phone},</if>
            <if test="idCard != null">id_card=#{idCard},</if>
            <if test="gender != null">gender=#{gender},</if>
            <if test="age != null">age=#{age},</if>
            <if test="address != null">address=#{address},</if>
            <if test="status != null">status=#{status},</if>
            update_time=now()
        </set>
        where id=#{id}
    </update>

    <delete id="deleteGuide">
        delete from guide where id=#{id}
    </delete>

    <select id="getGuideById" resultMap="guideMap">
        select * from guide where id=#{id}
    </select>

    <select id="listGuides" resultMap="guideMap">
        select * from guide
    </select>
    <!-- 姓名/电话/身份证 模糊查询 -->
    <select id="listGuidesByLike" resultMap="guideMap">
        select * from guide
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="phone != null and phone != ''">
                and phone like concat('%', #{phone}, '%')
            </if>
            <if test="idCard != null and idCard != ''">
                and id_card like concat('%', #{idCard}, '%')
            </if>
        </where>
    </select>
    <!-- ====================== 2. 导游资格审核 ====================== -->
    <resultMap id="qualificationMap" type="com.swu.tourismmanagesystem.entity.guide.GuideQualification">
        <id column="id" property="id"/>
        <result column="guide_id" property="guideId"/>
        <result column="qualify_no" property="qualifyNo"/>
        <result column="qualify_level" property="qualifyLevel"/>
        <result column="qualify_image" property="qualifyImage"/>
        <result column="audit_status" property="auditStatus"/>
        <result column="audit_remark" property="auditRemark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertQualification">
        insert into guide_qualification(guide_id, qualify_no, qualify_level, qualify_image, audit_status, audit_remark)
        values(#{guideId}, #{qualifyNo}, #{qualifyLevel}, #{qualifyImage}, #{auditStatus}, #{auditRemark})
    </insert>

    <update id="updateQualification">
        update guide_qualification
        <set>
            <if test="qualifyNo != null">qualify_no=#{qualifyNo},</if>
            <if test="qualifyLevel != null">qualify_level=#{qualifyLevel},</if>
            <if test="qualifyImage != null">qualify_image=#{qualifyImage},</if>
            <if test="auditStatus != null">audit_status=#{auditStatus},</if>
            <if test="auditRemark != null">audit_remark=#{auditRemark},</if>
            update_time=now()
        </set>
        where guide_id=#{guideId}
    </update>

    <select id="getQualificationByGuideId" resultMap="qualificationMap">
        select * from guide_qualification where guide_id=#{guideId}
    </select>

    <!-- ====================== 3. 导游实时状态 ====================== -->
    <resultMap id="realTimeMap" type="com.swu.tourismmanagesystem.entity.guide.GuideRealTime">
        <id column="id" property="id"/>
        <result column="guide_id" property="guideId"/>
        <result column="work_status" property="workStatus"/>
        <result column="current_order_id" property="currentOrderId"/>
        <result column="location" property="location"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertRealTime">
        insert into guide_realtime(guide_id, work_status, current_order_id, location)
        values(#{guideId}, #{workStatus}, #{currentOrderId}, #{location})
    </insert>

    <update id="updateRealTime">
        update guide_realtime
        <set>
            <if test="workStatus != null">work_status=#{workStatus},</if>
            <if test="currentOrderId != null">current_order_id=#{currentOrderId},</if>
            <if test="location != null">location=#{location},</if>
            update_time=now()
        </set>
        where guide_id=#{guideId}
    </update>

    <select id="getRealTimeByGuideId" resultMap="realTimeMap">
        select * from guide_realtime where guide_id=#{guideId}
    </select>

    <!-- ====================== 4. 导游求职申请 ====================== -->
    <resultMap id="jobApplyMap" type="com.swu.tourismmanagesystem.entity.guide.GuideJobApply">
        <id column="id" property="id"/>
        <result column="guide_id" property="guideId"/>
        <result column="agency_id" property="agencyId"/>
        <result column="apply_status" property="applyStatus"/>
        <result column="apply_remark" property="applyRemark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertJobApply">
        insert into guide_job_apply(guide_id, agency_id, apply_status, apply_remark)
        values(#{guideId}, #{agencyId}, #{applyStatus}, #{applyRemark})
    </insert>

    <update id="updateJobApply">
        update guide_job_apply
        <set>
            <if test="applyStatus != null">apply_status=#{applyStatus},</if>
            <if test="applyRemark != null">apply_remark=#{applyRemark},</if>
            update_time=now()
        </set>
        where id=#{id}
    </update>

    <select id="listJobAppliesByAgencyId" resultMap="jobApplyMap">
        select * from guide_job_apply where agency_id=#{agencyId}
    </select>

    <!-- ====================== 5. 导游行程单申领 ====================== -->
    <resultMap id="orderApplyMap" type="com.swu.tourismmanagesystem.entity.guide.GuideOrderApply">
        <id column="id" property="id"/>
        <result column="guide_id" property="guideId"/>
        <result column="order_id" property="orderId"/>
        <result column="agency_id" property="agencyId"/>
        <result column="apply_status" property="applyStatus"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertOrderApply">
        insert into guide_order_apply(guide_id, order_id, agency_id, apply_status)
        values(#{guideId}, #{orderId}, #{agencyId}, #{applyStatus})
    </insert>

    <update id="updateOrderApply">
        update guide_order_apply
        <set>
            <if test="applyStatus != null">apply_status=#{applyStatus},</if>
            update_time=now()
        </set>
        where id=#{id}
    </update>

    <select id="listOrderAppliesByAgencyId" resultMap="orderApplyMap">
        select * from guide_order_apply where agency_id=#{agencyId}
    </select>

</mapper>